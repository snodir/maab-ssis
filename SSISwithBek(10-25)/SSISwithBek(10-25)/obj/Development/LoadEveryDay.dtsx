      DTS:TaskContact="Execute Process Task;Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:PropertyExpression
        DTS:Name="Arguments">"a -t7z\""+ @[User::archive_folder] +"\""</DTS:PropertyExpression>
      <DTS:ObjectData>
        <ExecuteProcessData
          Executable="C:\Program Files\7-Zip\7z.exe"
          Arguments="a -t7z&quot;&quot;"
          WorkingDirectory="C:\Users\NODIR\Flat_subsource" />
      </DTS:ObjectData>
    </DTS:Executable>
