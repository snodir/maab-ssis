      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <ExpressionTask
          Expression="@[User::archive_folder]= &quot;d:\\archive_folder\\&quot;+replace(replace(replace((DT_WSTR, 30)GETDATE(), &quot;-&quot;, &quot;&quot;), &quot;:&quot;, &quot;&quot;), &quot;.&quot;, &quot;&quot;)+ &quot;.zip&quot;" />
      </DTS:ObjectData>
    </DTS:Executable>
