                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT    LEFT(pdfSource, LEN(pdfSource) - CHARINDEX('\', REVERSE(pdfSource))) AS FolderName, RIGHT(pdfSource, CHARINDEX('\', REVERSE(pdfSource)) - 1) AS FileName, IVRID, IVRDate, ClientID, ClientName, 
                      PhysicianID, PhyLast, PhyFrist, PatientID, MEDRECNUM, PatientLast, PatientFirst, PatientDOB, Document, pdfSource
FROM         ExportIVRScans
WHERE     (1 = 1) AND (ClientID = ?) AND (CAST(IVRDate AS date) BETWEEN '2025-07-01' AND CAST(GETDATE() AS date))
ORDER BY IVRDate DESC</property>
