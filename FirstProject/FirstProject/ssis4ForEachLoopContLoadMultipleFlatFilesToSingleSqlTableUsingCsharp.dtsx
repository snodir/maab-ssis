          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[
#region Help:  Introduction to the script task
/* The Script Task allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services control flow. 
 * 
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script task. */
#endregion


#region Namespaces
using System;
using System.Data;
using Microsoft.SqlServer.Dts.Runtime;
using System.Windows.Forms;
using System.Data.SqlClient;
using System.IO;
#endregion

namespace ST_5d4d94e7abb94650bdc65c6dc2cd3d6f
{
   
	[Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
	public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
	{
       
		public void Main()
		{
            string sqlinsert = "";
            string folderpath = Dts.Variables["User::srcfolderaddress"].Value.ToString();
            foreach (FileInfo file in new DirectoryInfo(folderpath).GetFiles())
            {
                if (file.Extension==".txt") 
                {
                    foreach (string row in File.ReadAllLines(file.FullName)) 
                    {
                        if (row != File.ReadAllLines(file.FullName)[0]) 
                        {
                            sqlinsert = sqlinsert + "('" + row.Replace(",", "', '") + "'),";
                        }
                    }
                }
            }
            sqlinsert = "insert into customer values " + sqlinsert.TrimEnd(',');
            MessageBox.Show(sqlinsert);
            using (SqlConnection con = new SqlConnection("Data Source=DESKTOP-20RAN2E;Initial Catalog=ssis4;Integrated Security=SSPI;"))
            {
                SqlCommand cmd = new SqlCommand(sqlinsert, con);
                con.Open();
                cmd.ExecuteNonQuery();
                con.Close();

            }

                Dts.TaskResult = (int)Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success;
		}        
       

	}
}]]></ProjectItem>
