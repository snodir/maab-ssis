      DTS:ThreadHint="2">
      <DTS:Variables />
      <DTS:ObjectData>
        <ExpressionTask
          Expression="@[User::formatted_currenttime]=left( replace((DT_WSTR, 30)GETDATE(), &quot;-&quot;, &quot;_&quot;),10)" />
      </DTS:ObjectData>
